{
  "name": "@open-report/core",
  "version": "0.0.1",
  "description": "Runtime and CLI for open-report — write reports in reports/, we handle the rest.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "open-report": "./bin.js"
  },
  "files": ["bin.js", "dist", "src/app", "skills", "README.md"],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["report", "document", "pdf", "citations", "react", "mdx", "vite", "agents"],
  "license": "MIT",
  "author": {
    "name": "itsyoga",
    "url": "https://github.com/open-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-report/open-report.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/open-report/open-report/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "chalk": "^5.3.0",
    "citeproc": "^2.4.63",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.2",
    "pagedjs": "^0.5.0-beta.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
